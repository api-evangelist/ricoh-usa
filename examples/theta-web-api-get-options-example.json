{
  "request": {
    "method": "POST",
    "url": "http://192.168.1.1/osc/commands/execute",
    "headers": {
      "Content-Type": "application/json;charset=utf-8"
    },
    "body": {
      "name": "camera.getOptions",
      "parameters": {
        "optionNames": [
          "captureMode",
          "iso",
          "shutterSpeed",
          "whiteBalance",
          "exposureProgram"
        ]
      }
    }
  },
  "response": {
    "status": 200,
    "body": {
      "name": "camera.getOptions",
      "state": "done",
      "results": {
        "options": {
          "captureMode": "image",
          "iso": 100,
          "shutterSpeed": 0.004,
          "whiteBalance": "auto",
          "exposureProgram": 2
        }
      }
    }
  }
}
