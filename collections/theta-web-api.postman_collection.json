  "info": {
    "_postman_id": "8f63d4fb-acf3-4bdb-af23-d6cf200cfa62",
    "name": "RICOH THETA Web API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "HTTP-over-Wi-Fi API for controlling RICOH THETA 360-degree cameras (Z1, X, A1) conforming to the\nOpen Spherical Camera (OSC) API Level 2 specification (Google) with Ricoh vendor extensions. The\ncamera operates either in access-point mode (default base URL http://192.168.1.1) or as a Wi-Fi\nclient. All commands are POST requests to /osc/commands/execute with a JSON body identifying the\ncommand name and parameters; long-running commands return an in-progress state polled via\n/osc/commands/status.\n\n\nContact Support:\n Name: RICOH360 Developer Support",
      "type": "text/plain"
    }
  }
